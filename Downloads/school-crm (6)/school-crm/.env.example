# נתיב לתיקיית הנתונים - בסביבת פיתוח אפשר להשאיר ריק (ישתמש ב-./data)
# ב-Render יש להצביע לנתיב ה-Persistent Disk, למשל /var/data
DATA_DIR=

# מחרוזת סודית וארוכה לחתימת עוגיית ההתחברות - ייצרו מחרוזת אקראית משלכם
SESSION_SECRET=

# ה-hash של סיסמת הכניסה למערכת - הריצו: npm run hash-password -- "הסיסמה-שלכם"
ADMIN_PASSWORD_HASH=\$2b\$10\$V0Joxzfkr7dz5xyHDuZW6.EdgpI3AZJPGlSH9umXEnwkNFtOt0zIm
